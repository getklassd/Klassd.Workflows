@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@implements IDisposable
@inject IJobStore Store

<PageTitle>Dashboard</PageTitle>

<h1 style="margin-bottom:16px;">Dashboard</h1>

<div class="stats" style="width:100%; box-shadow:0 1px 3px rgba(0,0,0,.12); margin-bottom:24px;">
    @foreach (var s in Stats)
    {
        <a class="stat" href="@StatLink(s.State)">
            <div class="stat-title">@s.State</div>
            <div class="stat-value @ValueClass(s.State)">@s.Count</div>
        </a>
    }
</div>

<div class="spread" style="margin-bottom:8px;">
    <h2>Latest runs</h2>
    <a href="/runs">View all</a>
</div>
<div class="card">
    <div class="card-body" style="padding:0;">
        <table class="table">
            <thead>
                <tr><th>Job</th><th>Status</th><th>Progress</th><th>Executor</th><th>Created</th></tr>
            </thead>
            <tbody>
                @foreach (var r in _latest)
                {
                    <tr class="hover">
                        <td><a href="@r.Href">@r.Name</a><br /><span class="slug-cell">@r.Id</span></td>
                        <td><span class="badge @r.Badge">@r.StatusText</span></td>
                        <td style="min-width:180px">
                            <progress class="progress @r.ProgressClass" value="@r.Progress" max="100" style="width:120px"></progress>
                            <span class="text-sm muted" style="margin-left:6px;">@r.Progress%</span>
                            @if (r.Detail is not null) { <div class="text-sm muted">@r.Detail</div> }
                        </td>
                        <td>@r.Executor</td>
                        <td><span class="text-sm muted">@r.CreatedAt.LocalDateTime.ToString("HH:mm:ss")</span></td>
                    </tr>
                }
                @if (_rows.Count == 0)
                {
                    <tr><td colspan="5" class="empty-state">No runs yet — start one from <a href="/jobs">Jobs</a>.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private IReadOnlyList<RunRow> _rows = [];
    private IReadOnlyList<RunRow> _latest = [];

    private record Stat(RunState State, int Count);
    private IEnumerable<Stat> Stats =>
        new[] { RunState.Pending, RunState.Running, RunState.Success, RunState.Failed }
            .Select(s => new Stat(s, _rows.Count(r => r.State == s)));

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        Store.ExecutionChanged += OnChanged;
        Store.WorkflowChanged += OnWorkflowChanged;
    }

    private async Task RefreshAsync()
    {
        _rows = await RunListing.LoadAsync(Store);
        _latest = _rows.Take(10).ToList();
    }

    private void OnChanged(JobExecution e) => _ = RefreshOnUi();
    private void OnWorkflowChanged(WorkflowRun r) => _ = RefreshOnUi();

    private async Task RefreshOnUi() =>
        await InvokeAsync(async () => { await RefreshAsync(); StateHasChanged(); });

    private static string StatLink(RunState s) => $"/runs/{s.ToString().ToLowerInvariant()}";

    private static string ValueClass(RunState s) => s switch
    {
        RunState.Success => "text-success",
        RunState.Failed => "text-error",
        RunState.Running => "text-primary",
        _ => "",
    };

    public void Dispose()
    {
        Store.ExecutionChanged -= OnChanged;
        Store.WorkflowChanged -= OnWorkflowChanged;
    }
}
