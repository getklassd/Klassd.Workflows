@page "/runs"
@page "/runs/{Status}"
@rendermode InteractiveServer
@implements IDisposable
@inject IJobStore Store
@inject IJobScheduler Scheduler

<PageTitle>@Title</PageTitle>

<h1 style="margin-bottom:16px;">@Title</h1>

<div class="card">
    <div class="card-body" style="padding:0;">
        <table class="table">
            <thead>
                <tr><th>Job</th><th>Status</th><th>Progress</th><th>Executor</th><th>Created</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var r in _filtered)
                {
                    <tr class="hover">
                        <td><a href="@r.Href">@r.Name</a><br /><span class="slug-cell">@r.Id</span></td>
                        <td><span class="badge @r.Badge">@r.StatusText</span></td>
                        <td style="min-width:180px">
                            <progress class="progress @r.ProgressClass" value="@r.Progress" max="100" style="width:120px"></progress>
                            <span class="text-sm muted" style="margin-left:6px;">@r.Progress%</span>
                            @if (r.Detail is not null) { <div class="text-sm muted">@r.Detail</div> }
                        </td>
                        <td>@r.Executor</td>
                        <td><span class="text-sm muted">@r.CreatedAt.LocalDateTime.ToString("HH:mm:ss")</span></td>
                        <td>
                            @if (r.CanStop)
                            {
                                <button class="btn btn-error btn-sm" @onclick="() => StopAsync(r.Id)">Stop</button>
                            }
                        </td>
                    </tr>
                }
                @if (_filtered.Count == 0)
                {
                    <tr><td colspan="6" class="empty-state">No @(_state?.ToString().ToLowerInvariant()) runs.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter] public string? Status { get; set; }

    private IReadOnlyList<RunRow> _rows = [];
    private IReadOnlyList<RunRow> _filtered = [];
    private RunState? _state;

    private string Title => _state is { } s ? $"{s} runs" : "All runs";

    protected override async Task OnParametersSetAsync()
    {
        _state = Enum.TryParse<RunState>(Status, ignoreCase: true, out var s) ? s : null;
        await RefreshAsync();
    }

    protected override void OnInitialized()
    {
        Store.ExecutionChanged += OnChanged;
        Store.WorkflowChanged += OnWorkflowChanged;
    }

    private async Task RefreshAsync()
    {
        _rows = await RunListing.LoadAsync(Store);
        _filtered = _state is { } s ? _rows.Where(r => r.State == s).ToList() : _rows;
    }

    private void OnChanged(JobExecution e) => _ = RefreshOnUi();
    private void OnWorkflowChanged(WorkflowRun r) => _ = RefreshOnUi();

    private async Task RefreshOnUi() =>
        await InvokeAsync(async () => { await RefreshAsync(); StateHasChanged(); });

    private async Task StopAsync(string id) => await Scheduler.StopAsync(id);

    public void Dispose()
    {
        Store.ExecutionChanged -= OnChanged;
        Store.WorkflowChanged -= OnWorkflowChanged;
    }
}
