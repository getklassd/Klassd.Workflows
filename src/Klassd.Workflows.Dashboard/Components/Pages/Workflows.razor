@page "/workflows"
@rendermode InteractiveServer
@implements IDisposable
@inject IJobStore Store
@inject IJobScheduler Scheduler
@inject IWorkflowRegistry Registry
@inject NavigationManager Nav

<PageTitle>Workflows</PageTitle>

<h1>Workflows</h1>

<h5 class="mt-3">Definitions</h5>
<table class="table align-middle">
    <thead><tr><th>Name</th><th>Nodes</th><th></th></tr></thead>
    <tbody>
        @foreach (var d in Registry.All)
        {
            <tr>
                <td><strong>@d.Name</strong></td>
                <td>@string.Join(" → ", d.Nodes.Select(n => n.Name))</td>
                <td><button class="btn btn-sm btn-primary" @onclick="() => RunAsync(d.Name)">Run</button></td>
            </tr>
        }
        @if (Registry.All.Count == 0)
        {
            <tr><td colspan="3" class="text-muted text-center">No workflows registered.</td></tr>
        }
    </tbody>
</table>

<h5 class="mt-4">Recent runs</h5>
<table class="table table-hover align-middle">
    <thead><tr><th>Workflow</th><th>Status</th><th>Nodes</th><th>Started</th></tr></thead>
    <tbody>
        @foreach (var r in _runs)
        {
            <tr style="cursor:pointer" @onclick="() => Open(r.Id)">
                <td>@r.DefinitionName<br /><small class="text-muted">@r.Id</small></td>
                <td><span class="badge @RunBadge(r.Status)">@r.Status</span></td>
                <td>@r.Nodes.Count(n => n.Status == NodeRunStatus.Succeeded)/@r.Nodes.Count done</td>
                <td><small>@r.CreatedAt.LocalDateTime.ToString("HH:mm:ss")</small></td>
            </tr>
        }
        @if (_runs.Count == 0)
        {
            <tr><td colspan="4" class="text-muted text-center">No runs yet — click Run above.</td></tr>
        }
    </tbody>
</table>

@code {
    private IReadOnlyList<WorkflowRun> _runs = Array.Empty<WorkflowRun>();

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        Store.WorkflowChanged += OnChanged;
    }

    private async Task Refresh() => _runs = await Store.ListWorkflowRunsAsync();

    private async void OnChanged(WorkflowRun _) =>
        await InvokeAsync(async () => { await Refresh(); StateHasChanged(); });

    private async Task RunAsync(string name)
    {
        var id = await Scheduler.EnqueueWorkflowAsync(name);
        Open(id);
    }

    private void Open(string id) => Nav.NavigateTo($"/workflows/runs/{id}");

    private static string RunBadge(WorkflowRunStatus s) => s switch
    {
        WorkflowRunStatus.Succeeded => "text-bg-success",
        WorkflowRunStatus.Failed => "text-bg-danger",
        _ => "text-bg-primary"
    };

    public void Dispose() => Store.WorkflowChanged -= OnChanged;
}
