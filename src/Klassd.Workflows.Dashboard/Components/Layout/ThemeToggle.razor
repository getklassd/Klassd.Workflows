@* Light/dark toggle. Plain DOM onclick (no Blazor interop) so it works pre- and
   post-hydration; the init script in App.razor applies the stored theme before first
   paint and icons swap via CSS on [data-theme] (see klassd.css .theme-toggle). *@
<button type="button" class="btn btn-ghost btn-circle theme-toggle" title="Toggle light / dark"
        aria-label="Toggle light / dark theme"
        onclick="(function(){var d=document.documentElement,t=d.getAttribute('data-theme')==='dark'?'light':'dark';d.setAttribute('data-theme',t);try{localStorage.setItem('klassd-theme',t);}catch(e){}document.cookie='klassd-theme='+t+';path=/;max-age=31536000;samesite=lax';})()">
    <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
    </svg>
    <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
</button>
